# ------------------------------------------------ #
#  The SBT Configuration file.                     #
# ------------------------------------------------ #

{% macro sbt_flag(key, value) %}
{% if value == "true" or value == "false" %}
-D{{ key }}={{ value }}
{% else %}
-D{{ key }}={{ value }}
{% endif %}
{% endmacro %}
{% if sbt_global_opts.allow_empty | default(false) | bool %}
# Starts sbt even if the current directory contains no sbt project.
--allow-empty

{% endif %}
{% if sbt_global_opts.mem is defined %}
# Set memory options
-mem {{ sbt_global_opts.mem }}

{% endif %}
{% if sbt_global_opts.no_share | default(false) | bool %}
# Use local caches for projects, no sharing.
-no-share

{% endif %}
{% if sbt_global_opts.sbt_version is defined %}
# Sets the sbt version to use.
-sbt-version {% if sbt_global_version is defined %}{{ sbt_global_version }}{% else %}{{ sbt_global_opts.sbt_version }}{% endif %}

{% endif %}
{% if sbt_global_opts.scala_home is defined %}
# Scala home path
-scala-home {{ sbt_global_opts.scala_home }}

{% endif %}
{% if sbt_global_opts.scala_version is defined %}
# Scala version to use
-scala-version {{ sbt_global_opts.scala_version }}

{% endif %}
{% if sbt_global_opts.java_home is defined %}
# JVM home path
-java-home {{ sbt_global_opts.java_home }}

{% endif %}
{% if sbt_global_opts['boot.directory'] is defined %}
# Path to shared boot directory.
-Dsbt.boot.directory={{ sbt_global_opts['boot.directory'] }}

{% endif %}
{% if sbt_global_opts['boot.properties'] is defined %}
# The path to find the sbt boot properties file.
-Dsbt.boot.properties={{ sbt_global_opts['boot.properties'] }}

{% endif %}
{% if sbt_global_opts.ci is defined %}
# For continuous integration environments. Suppress supershell and color.
{{ sbt_flag('sbt.ci', sbt_global_opts.ci) }}

{% endif %}
{% if sbt_global_opts.client is defined %}
{{ sbt_flag('sbt.client', sbt_global_opts.client) }}

{% endif %}
{% if sbt_global_opts.color is defined %}
# Supersedes sbt.log.format. To turn on color, use always or true. To turn off color, use never or false.
-Dsbt.color={{ sbt_global_opts.color }}

{% endif %}
{% if sbt_global_opts.coursier is defined %}
# Use coursier to retrieve packages.
{{ sbt_flag('sbt.coursier', sbt_global_opts.coursier) }}

{% endif %}
{% if sbt_global_opts['coursier.home'] is defined %}
# Location of coursier artifact cache.
-Dsbt.coursier.home={{ sbt_global_opts['coursier.home'] }}

{% endif %}
{% if sbt_global_opts.extraClasspath is defined %}
# Jar files or directories that are added to sbt's classpath.
-Dsbt.extraClasspath={{ sbt_global_opts.extraClasspath }}

{% endif %}
{% if sbt_global_opts.genbuildprops is defined %}
# Generate build.properties if missing.
{{ sbt_flag('sbt.genbuildprops', sbt_global_opts.genbuildprops) }}

{% endif %}
{% if sbt_global_opts['global.base'] is defined %}
# The directory containing global settings and plugins.
-Dsbt.global.base={{ sbt_global_opts['global.base'] }}

{% endif %}
{% if sbt_global_opts['inc.debug'] is defined %}
# Extra debugging for the incremental debugger.
{{ sbt_flag('xsbt.inc.debug', sbt_global_opts['inc.debug']) }}

{% endif %}
{% if sbt_global_opts.ivy is defined %}
# Use ivy to retrieve packages.
{{ sbt_flag('sbt.ivy', sbt_global_opts.ivy) }}

{% endif %}
{% if sbt_global_opts['ivy.home'] is defined %}
# The directory containing the local Ivy repository and artifact cache.
-Dsbt.ivy.home={{ sbt_global_opts['ivy.home'] }}

{% endif %}
{% if sbt_global_opts['log.noformat'] is defined %}
# If true, disable ANSI color codes.
{{ sbt_flag('sbt.log.noformat', sbt_global_opts['log.noformat']) }}

{% endif %}
{% if sbt_global_opts['main.class'] is defined %}
# The sbt class to use.
-Dsbt.main.class={{ sbt_global_opts['main.class'] }}

{% endif %}
{% if sbt_global_opts.offline is defined %}
# Avoid retrieving classes from repositories.
{{ sbt_flag('sbt.offline', sbt_global_opts.offline) }}

{% endif %}
{% if sbt_global_opts['override.build.repos'] is defined %}
# If true, repositories configured in a build definition are ignored.
{{ sbt_flag('sbt.override.build.repos', sbt_global_opts['override.build.repos']) }}

{% endif %}
{% if sbt_global_opts.progress is defined %}
# Use always to show progress ("supershell").
-Dsbt.progress={{ sbt_global_opts.progress }}

{% endif %}
{% if sbt_global_opts['repository.config'] is defined %}
# A file containing the repositories to use for the launcher.
-Dsbt.repository.config={{ sbt_global_opts['repository.config'] }}

{% endif %}
{% if sbt_global_opts['resident.limit'] is defined %}
# The number of scala compilers to keep around.
-Dsbt.resident.limit={{ sbt_global_opts['resident.limit'] }}

{% endif %}
{% if sbt_global_opts['skip.version.write'] is defined %}
# Generate build.properties if missing.
{{ sbt_flag('sbt.skip.version.write', sbt_global_opts['skip.version.write']) }}

{% endif %}
{% if sbt_global_opts.supershell is defined %}
# Use supershell (show progress at bottom of shell).
{{ sbt_flag('sbt.supershell', sbt_global_opts.supershell) }}

{% endif %}
{% if sbt_global_opts.supershell.sleep is defined %}
# Time to wait between updating the supershell progress area.
-Dsbt.supershell.sleep={{ sbt_global_opts.supershell.sleep }}

{% endif %}
{% if sbt_global_opts.task.timings is defined %}
# Measure the time elapsed for running tasks.
{{ sbt_flag('sbt.task.timings', sbt_global_opts['task.timings']) }}

{% endif %}
{% if sbt_global_opts['task.timings.omit.paths'] is defined %}
# Omit paths when reporting timings.
{{ sbt_flag('sbt.task.timings.omit.paths', sbt_global_opts['task.timings.omit.paths']) }}

{% endif %}
{% if sbt_global_opts['task.timings.on.shutdown'] is defined %}
# Report timings at JVM shutdown (instead of at task completion).
{{ sbt_flag('sbt.task.timings.on.shutdown', sbt_global_opts['task.timings.on.shutdown']) }}

{% endif %}
{% if sbt_global_opts['task.timings.threshold'] is defined %}
# Omit items from timing report if they are below this threshold.
-Dsbt.task.timings.threshold={{ sbt_global_opts['task.timings.threshold'] }}
{% endif %}
{% if sbt_global_opts.traces is defined %}
# Generate Chrome Trace Event Format log for tasks.
{{ sbt_flag('sbt.traces', sbt_global_opts.traces) }}

{% endif %}
{% if sbt_global_opts.turbo is defined %}
# Use additional layered class loaders.
{{ sbt_flag('sbt.turbo', sbt_global_opts.turbo) }}

{% endif %}
{% if sbt_global_opts.version is defined %}
# sbt version to use, usually taken from project/build.properties.
-Dsbt.version={{ sbt_global_opts.version }}

{% endif %}
{% if sbt_global_opts.watch_mode is defined %}
# If polling, check file system periodically for updates.
-Dsbt.watch.mode={{ sbt_global_opts.watch_mode }}

{% endif %}
{% if sbt_global_opts.jvm_properties is defined and sbt_global_opts.jvm_properties | length > 0 %}
# Extra JVM properties
{% for key, value in sbt_global_opts.jvm_properties.items() %}
-D{{ key }}={{ value }}
{% endfor %}
{% endif %}
